# 6. 结局变量 + 修复 SAE_time
# ==============================================
# 院内死亡结局变量
df_teacher_new <- df_teacher_new %>%
  # 先删掉已有的重复列，避免冲突
  select(-hospital_death_flag) %>%
  # 重新合并死亡数据并重命名
  left_join(death_flag, by = "hadm_id") %>%
  rename(hospital_death_flag = hospital_expire_flag) %>%
  
  # 核心修复：SAE_time + 28天ICU-free天数
  mutate(
    SAE_time = coalesce(first_abnormal_gcs_time, intime),
    days_to_icu_out = as.numeric(difftime(outtime, SAE_time, units = "days")),
    base_icu_free = 28 - days_to_icu_out,
    icu_free_days_28 = pmax(base_icu_free, 0)
  )

# 修复 eGFR：MIMIC 性别是 M/F
df_teacher_new <- df_teacher_new %>%
  mutate(
    gender_f = ifelse(gender == "F", 1, 0),
    egfr = NA
  )

for (i in 1:nrow(df_teacher_new)) {
  age <- df_teacher_new$age[i]
  f <- df_teacher_new$gender_f[i]
  cr <- df_teacher_new$creatinine[i]
  
  if (is.na(age) | is.na(f) | is.na(cr) | cr <= 0) next
  
  if (f == 1) {
    df_teacher_new$egfr[i] <- ifelse(cr <= 0.7,
                                     144 * (cr / 0.7)^-0.329 * 0.993^age,
                                     144 * (cr / 0.7)^-1.209 * 0.993^age)
  } else {
    df_teacher_new$egfr[i] <- ifelse(cr <= 0.9,
                                     141 * (cr / 0.9)^-0.411 * 0.993^age,
                                     141 * (cr / 0.9)^-1.209 * 0.993^age)
  }
}
# 90天生存
pat <- bq_table_download(bq_project_query(projectid, sprintf("
  SELECT subject_id, dod FROM `physionet-data.mimiciv_3_1_hosp.patients`
