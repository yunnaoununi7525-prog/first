# ==============================================
cbc_ts <- bq_table_download(bq_project_query(projectid, sprintf("
  SELECT hadm_id, charttime, wbc, hemoglobin, platelet
  FROM `physionet-data.mimiciv_3_1_derived.complete_blood_count` WHERE hadm_id IN (%s)
