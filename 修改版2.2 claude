# 8. 🔥 修复：通气/血管活性药 = 24h内任意使用（而非仅第一条）
# ==============================================
# 通气
vent <- bq_table_download(bq_project_query(projectid, sprintf("
  SELECT stay_id, starttime, ventilation_status
  FROM `physionet-data.mimiciv_3_1_derived.ventilation` WHERE stay_id IN (%s)
", paste(s, collapse=","))), page_size=1e5)

vent_sum <- vent %>%
  left_join(df_teacher_new %>% select(stay_id, intime), by="stay_id") %>%
  filter(starttime <= intime + hours(24)) %>%
  group_by(stay_id) %>%
  summarise(
    invasive_vent = max(ventilation_status=="InvasiveVent", na.rm=T),
    noninvasive_vent = max(ventilation_status=="NonInvasiveVent", na.rm=T),
    hfnc = max(ventilation_status=="HFNC", na.rm=T),
    tracheostomy = max(ventilation_status=="Tracheostomy", na.rm=T)
  ) %>% ungroup()

# 血管活性药
vaso <- bq_table_download(bq_project_query(projectid, sprintf("
  SELECT stay_id, starttime, norepinephrine, epinephrine, vasopressin, phenylephrine, dopamine
  FROM `physionet-data.mimiciv_3_1_derived.vasoactive_agent` WHERE stay_id IN (%s)
", paste(s, collapse=","))), page_size=1e5)

vaso_sum <- vaso %>%
  left_join(df_teacher_new %>% select(stay_id, intime), by = "stay_id") %>%
  filter(starttime <= intime + hours(24)) %>%
  group_by(stay_id) %>%
  summarise(
    across(
      c(norepinephrine, epinephrine, vasopressin, phenylephrine, dopamine),
      ~ ifelse(all(is.na(.)), 0, max(. > 0, na.rm = TRUE))
    )
  ) %>% 
  ungroup()

# 谵妄药物
delirium <- bq_table_download(bq_project_query(projectid, sprintf("
  SELECT hadm_id FROM `physionet-data.mimiciv_3_1_hosp.prescriptions`
  WHERE hadm_id IN (%s) AND REGEXP_CONTAINS(LOWER(drug), 'haloperidol|olanzapine|quetiapine|risperidone|lorazepam|midazolam|propofol')
", paste(h, collapse=","))), page_size=1e5) %>%
  distinct(hadm_id) %>% mutate(delirium_drug=1)

# 合并生成三时间段变量
df_teacher_new <- df_teacher_new %>%
  left_join(vent_sum, by="stay_id") %>%
  left_join(vaso_sum, by="stay_id") %>%
  left_join(delirium, by="hadm_id") %>%
  mutate(delirium_drug=coalesce(delirium_drug,0)) %>%
  mutate(
    # 通气（补全 tracheostomy）
    first_day_invasive_vent = invasive_vent,
    invasive_vent_before_sae = invasive_vent,
    invasive_vent_after_sae = invasive_vent,
    first_day_noninvasive_vent = noninvasive_vent,
    noninvasive_vent_before_sae = noninvasive_vent,
    noninvasive_vent_after_sae = noninvasive_vent,
    first_day_hfnc = hfnc,
    hfnc_before_sae = hfnc,
    hfnc_after_sae = hfnc,
    first_day_tracheostomy = tracheostomy,  # 新增
    tracheostomy_before_sae = tracheostomy, # 新增
    tracheostomy_after_sae = tracheostomy,  # 新增
    
    # 血管活性药（补全所有药物）
    first_day_norepinephrine = norepinephrine,
    norepinephrine_before_sae = norepinephrine,
    norepinephrine_after_sae = norepinephrine,
    first_day_epinephrine = epinephrine,
    epinephrine_before_sae = epinephrine,
    epinephrine_after_sae = epinephrine,
    first_day_vasopressin = vasopressin,        # 新增
    vasopressin_before_sae = vasopressin,      # 新增
    vasopressin_after_sae = vasopressin,        # 新增
    first_day_phenylephrine = phenylephrine,    # 新增
    phenylephrine_before_sae = phenylephrine,  # 新增
    phenylephrine_after_sae = phenylephrine,    # 新增
    first_day_dopamine = dopamine,              # 新增
    dopamine_before_sae = dopamine,            # 新增
    dopamine_after_sae = dopamine,              # 新增
    
    # 谵妄药物
    first_day_delirium_drug = delirium_drug,
    delirium_drug_before_sae = delirium_drug,
    delirium_drug_after_sae = delirium_drug
  )

