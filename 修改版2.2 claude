", paste(h, collapse=","))), page_size=1e5)

# 合并时序实验室
all_labs <- Reduce(function(x,y) merge(x,y,by=c("hadm_id","charttime"),all=TRUE),
                   list(cbc_ts, chem_ts, enz_ts, coag_ts))
all_labs$charttime <- as.POSIXct(all_labs$charttime)

# 匹配SAE时间到实验室
sae_map <- df_teacher_new %>% select(hadm_id, SAE_time, intime)
all_labs <- all_labs %>% left_join(sae_map, by="hadm_id")

lab_names <- c("wbc","hemoglobin","platelet",
               "sodium","potassium","chloride","bicarbonate","bun","creatinine","glucose",
               "alt","ast","bilirubin_direct","pt","inr","ptt","fibrinogen","d_dimer")

# 🔥 真正的三阶段拆分
for (v in lab_names) {
  
  # 1. first_day：入院24h内第一次
  labs_1 <- all_labs %>%
    filter(charttime <= intime + hours(24)) %>%
    arrange(hadm_id, charttime) %>%
    distinct(hadm_id, .keep_all=TRUE) %>%
    select(hadm_id, all_of(v)) %>%
    rename(!!paste0("first_day_",v) := all_of(v))
  
  # 2. before_sae：SAE前最后一次
  labs_b <- all_labs %>%
    filter(charttime < SAE_time) %>%
    arrange(hadm_id, desc(charttime)) %>%
    distinct(hadm_id, .keep_all=TRUE) %>%
    select(hadm_id, all_of(v)) %>%
    rename(!!paste0(v,"_before_sae") := all_of(v))
  
  # 3. after_sae：SAE后第一次
  labs_a <- all_labs %>%
    filter(charttime >= SAE_time) %>%
    arrange(hadm_id, charttime) %>%
    distinct(hadm_id, .keep_all=TRUE) %>%
    select(hadm_id, all_of(v)) %>%
    rename(!!paste0(v,"_after_sae") := all_of(v))
  
  # 合并
  df_teacher_new <- df_teacher_new %>%
    left_join(labs_1, by="hadm_id") %>%
    left_join(labs_b, by="hadm_id") %>%
    left_join(labs_a, by="hadm_id")
}

