# ==============================================
# 1. 拉取主队列 + 修复：真实首次异常GCS时间（用于SAE时间）
# ==============================================
sql_main <- "
WITH base_icu AS (
  SELECT
    subject_id, stay_id, hadm_id, intime, outtime,
    DATETIME_DIFF(outtime, intime, HOUR) AS icu_length_hours
  FROM `physionet-data.mimiciv_3_1_icu.icustays`
  QUALIFY ROW_NUMBER() OVER (PARTITION BY subject_id ORDER BY intime ASC) = 1
),
valid_icu AS (
  SELECT * FROM base_icu WHERE icu_length_hours >= 24
),
-- 第一步：拿到24h内所有GCS
gcs_full AS (
  SELECT
    g.subject_id, g.stay_id, g.gcs, g.charttime
  FROM `physionet-data.mimiciv_3_1_derived.gcs` g
  JOIN base_icu b ON g.stay_id = b.stay_id
  WHERE g.charttime <= DATETIME_ADD(b.intime, INTERVAL 24 HOUR)
),
-- 第二步：首次异常GCS的时间（真正的SAE时间）
first_abnormal_gcs_time AS (
  SELECT
    stay_id,
    MIN(charttime) AS first_abnormal_gcs_time
  FROM gcs_full
  WHERE gcs < 15  -- 异常定义
  GROUP BY stay_id
),
-- 第三步：首日最低GCS
first_day_gcs AS (
  SELECT
    subject_id, stay_id,
    MIN(gcs) AS first_day_gcs
  FROM gcs_full
  GROUP BY subject_id, stay_id
),
adult_patients AS (
  SELECT
    v.*, a.age, p.gender
  FROM valid_icu v
  JOIN `physionet-data.mimiciv_3_1_derived.age` a ON v.hadm_id = a.hadm_id
  JOIN `physionet-data.mimiciv_3_1_hosp.patients` p ON v.subject_id = p.subject_id
  WHERE a.age >= 18
),
final_cohort AS (
  SELECT DISTINCT
    a.*,
    s.sofa_score, s.sepsis3, s.culture_time, s.sofa_time, s.suspected_infection_time,
    g.first_day_gcs,
    gc.first_abnormal_gcs_time,  -- 关键：真实异常时间

    -- 24h内sepsis3
    IF(
      DATETIME_DIFF(GREATEST(s.culture_time, s.sofa_time), a.intime, HOUR) < 24, 1, 0
    ) AS sepsis3_firstday,

    -- 修复：GCS缺失≠正常，缺失=异常
    IF(
      first_day_gcs = 15, 1,
      IF(first_day_gcs IS NULL, 0, 0)
    ) AS normal_GCS

  FROM adult_patients a
  LEFT JOIN `physionet-data.mimiciv_3_1_derived.sepsis3` s ON a.stay_id = s.stay_id
  LEFT JOIN first_day_gcs g ON a.stay_id = g.stay_id
  LEFT JOIN first_abnormal_gcs_time gc ON a.stay_id = gc.stay_id
)
SELECT * FROM final_cohort;
"

