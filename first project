  left_join(pat, by = "subject_id")

# ======================================================================
# 3. 计算随访时间：follow-up-time（单位：天）
# ======================================================================
df_teacher_new <- df_teacher_new %>%
  mutate(
    # 先把时间转成标准格式
    intime = as.POSIXct(intime),
    dod = as.Date(dod),
    
    # 计算生存时间 / 随访时间
    follow_up_time = case_when(
      !is.na(dod) ~ as.numeric(difftime(dod, date(intime), units = "days")),
      TRUE ~ 90  # 没死的人，随访满90天
    )
  )

# ======================================================================
# 4. 生成 90-day-survival 二分类变量
# 1 = 存活（90天未死亡）
# 0 = 90天内死亡
# ======================================================================
df_teacher_new <- df_teacher_new %>%
  mutate(
    ninety_day_survival = case_when(
      !is.na(dod) & follow_up_time <= 90 ~ 0,
      TRUE ~ 1
    )
  )

