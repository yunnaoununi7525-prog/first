# ======================================================================
sql_pat <- sprintf("
SELECT 
  subject_id,
  dod       -- 死亡日期 date of death
FROM `physionet-data.mimiciv_3_1_hosp.patients`
WHERE subject_id IN (%s)
", paste(unique(df_teacher_new$subject_id), collapse = ","))

