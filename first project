# 你的SQL查询
sql <- "
WITH base_icu AS (
  -- 每个患者首次ICU入院
  SELECT
    subject_id,
    stay_id,
    hadm_id,
    intime,
    outtime,
    DATETIME_DIFF(outtime, intime, HOUR) AS icu_length_hours
  FROM `physionet-data.mimiciv_3_1_icu.icustays`
  QUALIFY ROW_NUMBER() OVER (PARTITION BY subject_id ORDER BY intime ASC) = 1
),
valid_icu AS (
  -- ICU住院≥24小时
  SELECT * FROM base_icu WHERE icu_length_hours >= 24
),
first_day_gcs AS (
  SELECT
    g.subject_id,
    g.stay_id,
    MIN(g.gcs) AS first_day_gcs
  FROM `physionet-data.mimiciv_3_1_derived.gcs` g
  JOIN base_icu b ON g.stay_id = b.stay_id
  WHERE 
    g.charttime <= DATETIME_ADD(b.intime, INTERVAL 24 HOUR)
  GROUP BY g.subject_id, g.stay_id
),
adult_patients AS (
  SELECT
    v.*,
    a.age,
    p.gender
  FROM valid_icu v
  JOIN `physionet-data.mimiciv_3_1_derived.age` a ON v.hadm_id = a.hadm_id
  JOIN `physionet-data.mimiciv_3_1_hosp.patients` p ON v.subject_id = p.subject_id
  WHERE a.age >= 18
),
final_cohort AS (
  SELECT DISTINCT
    a.*,
    s.sofa_score,
    s.sepsis3,
    s.culture_time,
    s.sofa_time,
    s.suspected_infection_time,
    g.first_day_gcs,

    -- sepsis3 在 24h 内
    IF(
      DATETIME_DIFF(
        GREATEST(s.culture_time, s.sofa_time),
        a.intime,
        HOUR
      ) < 24, 1, 0
    ) AS sepsis3_firstday,

    -- normal_GCS：GCS=15 =1，否则=0，NULL也算15
    IF(IFNULL(g.first_day_gcs, 15) = 15, 1, 0) AS normal_GCS

  FROM adult_patients a
  LEFT JOIN `physionet-data.mimiciv_3_1_derived.sepsis3` s ON a.stay_id = s.stay_id
  LEFT JOIN first_day_gcs g ON a.stay_id = g.stay_id

  -- 删除 WHERE s.sepsis3 = true 
)
SELECT * FROM final_cohort;
"

