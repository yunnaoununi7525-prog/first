# 计算 eGFR
df_teacher_new$egfr <- NA  # 先创建空列

# 所有逻辑必须都在 for 循环里
for (i in 1:nrow(df_teacher_new)) {
  # 1. 先定义变量
  age <- df_teacher_new$age[i]
  gender <- df_teacher_new$gender[i]
  creat <- df_teacher_new$creat[i]
  
  # 2. 缺失值判断
  if (is.na(age) | is.na(gender) | is.na(creat) | creat <= 0) {
    df_teacher_new$egfr[i] <- NA
    next  # 跳过这一行
  }
  
  # 3. 计算eGFR
  if (gender == 0) { # 女性
    if (creat <= 0.7) {
      egfr <- 144 * (creat / 0.7)^(-0.329) * (0.993)^age
    } else {
      egfr <- 144 * (creat / 0.7)^(-1.209) * (0.993)^age
    }
  } else { # 男性
    if (creat <= 0.9) {
      egfr <- 141 * (creat / 0.9)^(-0.411) * (0.993)^age
    } else {
      egfr <- 141 * (creat / 0.9)^(-1.209) * (0.993)^age
    }
  }
  
  # 4. 赋值回数据框
  df_teacher_new$egfr[i] <- egfr
}

