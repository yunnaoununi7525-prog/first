install.packages("dplyr")
install.packages("lubridate")

library(bigrquery)
library(dplyr)
library(lubridate)

# 你的项目ID & 患者ID列表
hadm_list <- paste(df_teacher_new$hadm_id, collapse = ",")
pid <- "project-3821312a-fb0b-42e4-8f0"

# =============================================
# 1. 下载所有时序数据
# =============================================
# 血常规
sql_cbc <- sprintf("
SELECT hadm_id, charttime, wbc, hemoglobin, platelet
FROM `physionet-data.mimiciv_3_1_derived.complete_blood_count`
WHERE hadm_id IN (%s)", hadm_list)
cbc <- bq_table_download(bq_project_query(pid, sql_cbc))

# 生化
sql_chem <- sprintf("
SELECT hadm_id, charttime, sodium, potassium, chloride, bicarbonate, bun, creatinine, glucose
FROM `physionet-data.mimiciv_3_1_derived.chemistry`
WHERE hadm_id IN (%s)", hadm_list)
chem <- bq_table_download(bq_project_query(pid, sql_chem))

# 酶学/肝功能
sql_enz <- sprintf("
SELECT hadm_id, charttime, alt, ast, bilirubin_direct
FROM `physionet-data.mimiciv_3_1_derived.enzyme`
WHERE hadm_id IN (%s)", hadm_list)
enz <- bq_table_download(bq_project_query(pid, sql_enz))

# 凝血
sql_coag <- sprintf("
SELECT hadm_id, charttime, pt, inr, ptt, fibrinogen, d_dimer
FROM `physionet-data.mimiciv_3_1_derived.coagulation`
WHERE hadm_id IN (%s)", hadm_list)
coag <- bq_table_download(bq_project_query(pid, sql_coag))

# 合并所有表
all_labs <- merge(cbc, chem, by = c("hadm_id", "charttime"), all = TRUE)
all_labs <- merge(all_labs, enz, by = c("hadm_id", "charttime"), all = TRUE)
all_labs <- merge(all_labs, coag, by = c("hadm_id", "charttime"), all = TRUE)
all_labs$charttime <- as.POSIXct(all_labs$charttime)

# =============================================
# 2. 按变量拆分 first / before / after（一次性循环）
# =============================================
lab_names <- c("wbc","hemoglobin","platelet",
               "sodium","potassium","chloride","bicarbonate","bun","creatinine","glucose",
               "alt","ast","bilirubin_direct",
               "pt","inr","ptt","fibrinogen","d_dimer")

for (v in lab_names) {
  # 1. 入院第一次值
  first <- all_labs[order(all_labs$hadm_id, all_labs$charttime), ]
  first <- first[!duplicated(first$hadm_id), c("hadm_id", v)]
  colnames(first) <- c("hadm_id", paste0("first_day_", v))
  
  # 2. 入院最后一次值（after_sae）
  last <- all_labs[order(all_labs$hadm_id, as.POSIXct(all_labs$charttime), decreasing = c(FALSE, TRUE)), ]
  last <- last[!duplicated(last$hadm_id), c("hadm_id", v)]
  colnames(last) <- c("hadm_id", paste0(v, "_after_sae"))
  
  # 3. 事件前值（先占位，后续可按SAE时间调整）
  before <- all_labs[order(all_labs$hadm_id, all_labs$charttime), ]
  before <- before[!duplicated(before$hadm_id), c("hadm_id", v)]
  colnames(before) <- c("hadm_id", paste0(v, "_before_sae"))
  
  # 合并回主表
  df_teacher_new <- merge(df_teacher_new, first, by = "hadm_id", all.x = TRUE)
  df_teacher_new <- merge(df_teacher_new, before, by = "hadm_id", all.x = TRUE)
  df_teacher_new <- merge(df_teacher_new, last, by = "hadm_id", all.x = TRUE)
}

# =============================================
# 完成！
# =============================================
message("✅ 全部变量已按 first / before / after 拆分完成！")
tail(colnames(df_teacher_new), 30)

