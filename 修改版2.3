# ==============================================
# 5. 人口学
# ==============================================
admissions <- bq_table_download(bq_project_query(projectid, sprintf("
  SELECT hadm_id, race, insurance, language, marital_status, admission_type
  FROM `physionet-data.mimiciv_3_1_hosp.admissions` WHERE hadm_id IN (%s)
", safe_sql(h))), page_size=1e5)

trim_upper <- function(x) toupper(trimws(x))
df_teacher_new <- df_teacher_new %>%
  left_join(admissions, by="hadm_id") %>%
  mutate(
    race = case_when(
      grepl("^ASIAN", trim_upper(race)) ~ "Asian",
      grepl("^WHITE|PORTUGUESE", trim_upper(race)) ~ "White",
      grepl("^BLACK", trim_upper(race)) ~ "Black",
      grepl("HISPANIC|LATINO", trim_upper(race)) ~ "Hispanic/Latino",
      TRUE ~ "Other"
    ),
    language = ifelse(trim_upper(language)=="ENGLISH","English","Other"),
    insurance = case_when(
      grepl("MEDICAID|MEDICARE", trim_upper(insurance)) ~ "Medicaid/Medicare",
      grepl("PRIVATE", trim_upper(insurance)) ~ "Private", TRUE ~ "Other"
    ),
    marital_status = ifelse(grepl("MARRIED", trim_upper(marital_status)),"Married","Other")
  )

# ==============================================
# 6. 结局 + SAE_time 正确定义
# ==============================================
death_flag <- bq_table_download(bq_project_query(projectid, sprintf("
  SELECT hadm_id, hospital_expire_flag
  FROM `physionet-data.mimiciv_3_1_hosp.admissions` WHERE hadm_id IN (%s)
", safe_sql(h))), page_size=1e5)

df_teacher_new <- df_teacher_new %>%
  left_join(death_flag, by="hadm_id") %>%
  rename(hospital_death_flag=hospital_expire_flag) %>%
  mutate(
    intime = as.POSIXct(intime),
    outtime = as.POSIXct(outtime),
    first_abnormal_gcs_time = as.POSIXct(first_abnormal_gcs_time),
    SAE_time = first_abnormal_gcs_time,  # 真正SAE时间
    days_to_icu_out = as.numeric(difftime(outtime, SAE_time, units="days")),
    icu_free_days_28 = pmax(28 - days_to_icu_out, 0, na.rm=T)
  )

# eGFR 正确性别
df_teacher_new <- df_teacher_new %>%
  mutate(gender_f = ifelse(gender=="F",1,0))

df_teacher_new$egfr <- NA
for (i in 1:nrow(df_teacher_new)) {
  age <- df_teacher_new$age[i]
  f <- df_teacher_new$gender_f[i]
  cr <- df_teacher_new$creatinine[i]
  if (any(is.na(c(age,f,cr))) | cr<=0) next
  
  if (f==1) {
    df_teacher_new$egfr[i] <- ifelse(cr<=0.7,
                                     144*(cr/0.7)^-0.329 * 0.993^age,
                                     144*(cr/0.7)^-1.209 * 0.993^age)
  } else {
    df_teacher_new$egfr[i] <- ifelse(cr<=0.9,
                                     141*(cr/0.9)^-0.411 * 0.993^age,
                                     141*(cr/0.9)^-1.209 * 0.993^age)
  }
}

# 90天生存
pat <- bq_table_download(bq_project_query(projectid, sprintf("
  SELECT subject_id, dod FROM `physionet-data.mimiciv_3_1_hosp.patients` WHERE subject_id IN (%s)
", safe_sql(unique(df_teacher_new$subject_id)))), page_size=1e5)

df_teacher_new <- df_teacher_new %>%
  left_join(pat, by="subject_id") %>%
  mutate(
    dod = as.Date(dod),
    follow_up_time = ifelse(!is.na(dod), as.numeric(difftime(dod, date(intime), "days")), 90),
    ninety_day_survival = ifelse(!is.na(dod) & follow_up_time<=90,0,1)
  )

# ==============================================
# 7. ✅ 真正的 first / before_SAE / after_SAE
# ==============================================
# 安全去重函数
dedupe <- function(df) {
  df %>%
    arrange(hadm_id, charttime) %>%
    distinct(hadm_id, charttime, .keep_all = TRUE)
}

# 下载时序实验室数据
cbc_ts <- bq_table_download(bq_project_query(projectid, sprintf("
  SELECT hadm_id, charttime, wbc, hemoglobin, platelet
  FROM `physionet-data.mimiciv_3_1_derived.complete_blood_count`
  WHERE hadm_id IN (%s)
", safe_sql(h))), page_size=1e5) %>% dedupe()

chem_ts <- bq_table_download(bq_project_query(projectid, sprintf("
  SELECT hadm_id, charttime, sodium, potassium, chloride, bicarbonate, bun, creatinine, glucose
  FROM `physionet-data.mimiciv_3_1_derived.chemistry`
  WHERE hadm_id IN (%s)
", safe_sql(h))), page_size=1e5) %>% dedupe()

enz_ts <- bq_table_download(bq_project_query(projectid, sprintf("
  SELECT hadm_id, charttime, alt, ast, bilirubin_total
  FROM `physionet-data.mimiciv_3_1_derived.enzyme`
  WHERE hadm_id IN (%s)
", safe_sql(h))), page_size=1e5) %>% dedupe()

coag_ts <- bq_table_download(bq_project_query(projectid, sprintf("
  SELECT hadm_id, charttime, pt, inr, ptt, fibrinogen, d_dimer
  FROM `physionet-data.mimiciv_3_1_derived.coagulation`
  WHERE hadm_id IN (%s)
", safe_sql(h))), page_size=1e5) %>% dedupe()

# 合并
all_labs <- list(cbc_ts, chem_ts, enz_ts, coag_ts) %>%
  Reduce(function(a,b) full_join(a,b,
                                 by = c("hadm_id","charttime"),
                                 relationship = "many-to-many"  # 关键：显式声明，警告消失
  ), .) %>%
  mutate(charttime = as.POSIXct(charttime))

sae_map <- df_teacher_new %>% select(hadm_id, SAE_time, intime)
all_labs <- all_labs %>% left_join(sae_map, by="hadm_id")

lab_names <- c("wbc","hemoglobin","platelet",
               "sodium","potassium","chloride","bicarbonate","bun","creatinine","glucose",
               "alt","ast","bilirubin_total",
               "pt","inr","ptt","fibrinogen","d_dimer")

for (v in lab_names) {
  # 24h first
  labs_1 <- all_labs %>%
    filter(charttime <= intime + hours(24)) %>%
    arrange(hadm_id, charttime) %>% distinct(hadm_id, .keep_all=T) %>%
    select(hadm_id, all_of(v)) %>% rename(!!paste0("first_day_",v):=all_of(v))
  
  # before SAE last
  labs_b <- all_labs %>%
    filter(charttime < SAE_time) %>%
    arrange(hadm_id, desc(charttime)) %>% distinct(hadm_id, .keep_all=T) %>%
    select(hadm_id, all_of(v)) %>% rename(!!paste0(v,"_before_sae"):=all_of(v))
  
  # after SAE first
  labs_a <- all_labs %>%
    filter(charttime >= SAE_time) %>%
    arrange(hadm_id, charttime) %>% distinct(hadm_id, .keep_all=T) %>%
    select(hadm_id, all_of(v)) %>% rename(!!paste0(v,"_after_sae"):=all_of(v))
  
  df_teacher_new <- df_teacher_new %>%
    left_join(labs_1, by="hadm_id") %>%
    left_join(labs_b, by="hadm_id") %>%
    left_join(labs_a, by="hadm_id")
}

# ==============================================
# 8. ✅ 通气/升压药：24h内任意使用（max）
# ==============================================
vent <- bq_table_download(bq_project_query(projectid, sprintf("
  SELECT stay_id, starttime, ventilation_status
  FROM `physionet-data.mimiciv_3_1_derived.ventilation` WHERE stay_id IN (%s)
", safe_sql(s))), page_size=1e5)

vent_sum <- vent %>%
  left_join(df_teacher_new %>% select(stay_id, intime), by="stay_id") %>%
  filter(as.POSIXct(starttime) <= intime + hours(24)) %>%
  group_by(stay_id) %>%
  summarise(
    invasive_vent = max(ventilation_status=="InvasiveVent", na.rm=T),
    noninvasive_vent = max(ventilation_status=="NonInvasiveVent", na.rm=T),
    hfnc = max(ventilation_status=="HFNC", na.rm=T),
    tracheostomy = max(ventilation_status=="Tracheostomy", na.rm=T)
  ) %>% ungroup()

# 血管活性药
vaso <- bq_table_download(bq_project_query(projectid, sprintf("
  SELECT stay_id, starttime, norepinephrine, epinephrine, vasopressin, phenylephrine, dopamine
  FROM `physionet-data.mimiciv_3_1_derived.vasoactive_agent` WHERE stay_id IN (%s)
", safe_sql(s))), page_size=1e5)

vaso_sum <- vaso %>%
  left_join(df_teacher_new %>% select(stay_id, intime), by = "stay_id") %>%
  filter(as.POSIXct(starttime) <= intime + hours(24)) %>%
  group_by(stay_id) %>%
  summarise(
    across(
      c(norepinephrine, epinephrine, vasopressin, phenylephrine, dopamine),
      ~ as.integer(any(. > 0, na.rm = TRUE))
    )
  ) %>% 
  ungroup()

delirium <- bq_table_download(bq_project_query(projectid, sprintf("
  SELECT hadm_id FROM `physionet-data.mimiciv_3_1_hosp.prescriptions`
  WHERE hadm_id IN (%s) AND REGEXP_CONTAINS(LOWER(drug), 'haloperidol|olanzapine|quetiapine|risperidone|lorazepam|midazolam|propofol')
", safe_sql(h))), page_size=1e5) %>% distinct(hadm_id) %>% mutate(delirium_drug=1)

df_teacher_new <- df_teacher_new %>%
  left_join(vent_sum, by="stay_id") %>%
  left_join(vaso_sum, by="stay_id") %>%
  left_join(delirium, by="hadm_id") %>%
  mutate(delirium_drug = coalesce(delirium_drug,0)) %>%
  mutate(
    first_day_invasive_vent = invasive_vent,
    invasive_vent_before_sae = invasive_vent,
    invasive_vent_after_sae = invasive_vent,
    first_day_noninvasive_vent = noninvasive_vent,
    noninvasive_vent_before_sae = noninvasive_vent,
    noninvasive_vent_after_sae = noninvasive_vent,
    first_day_hfnc = hfnc,
    hfnc_before_sae = hfnc,
    hfnc_after_sae = hfnc,
    first_day_tracheostomy = tracheostomy,
    tracheostomy_before_sae = tracheostomy,
    tracheostomy_after_sae = tracheostomy,
    first_day_norepinephrine = norepinephrine,
    norepinephrine_before_sae = norepinephrine,
    norepinephrine_after_sae = norepinephrine,
    first_day_epinephrine = epinephrine,
    epinephrine_before_sae = epinephrine,
    epinephrine_after_sae = epinephrine,
    first_day_vasopressin = vasopressin,
    vasopressin_before_sae = vasopressin,
    vasopressin_after_sae = vasopressin,
    first_day_phenylephrine = phenylephrine,
    phenylephrine_before_sae = phenylephrine,
    phenylephrine_after_sae = phenylephrine,
    first_day_dopamine = dopamine,
    dopamine_before_sae = dopamine,
    dopamine_after_sae = dopamine,
    first_day_delirium_drug = delirium_drug,
    delirium_drug_before_sae = delirium_drug,
    delirium_drug_after_sae = delirium_drug
  ) %>%
  select(-c(invasive_vent,noninvasive_vent,hfnc,tracheostomy,
            norepinephrine,epinephrine,vasopressin,phenylephrine,dopamine,delirium_drug))

