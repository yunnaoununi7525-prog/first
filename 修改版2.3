# ==============================================
# 0. 初始化环境
# ==============================================
install.packages(c("bigrquery", "dplyr", "lubridate", "table1"))
library(bigrquery)
library(dplyr)
library(lubridate)
bq_auth()

projectid <- "project-3821312a-fb0b-42e4-8f0"

# ==============================================
# 1. 主队列：首次ICU + 24h + 成人 + 真正 first_abnormal_gcs_time
# ==============================================
sql_main <- "
WITH base_icu AS (
  SELECT
    subject_id, stay_id, hadm_id, intime, outtime,
    DATETIME_DIFF(outtime, intime, HOUR) AS icu_length_hours
  FROM `physionet-data.mimiciv_3_1_icu.icustays`
  QUALIFY ROW_NUMBER() OVER (PARTITION BY subject_id ORDER BY intime ASC) = 1
),
valid_icu AS (
  SELECT * FROM base_icu WHERE icu_length_hours >= 24
),
gcs_full AS (
  SELECT g.stay_id, g.charttime, g.gcs, b.intime
  FROM `physionet-data.mimiciv_3_1_derived.gcs` g
  JOIN base_icu b ON g.stay_id = b.stay_id
  WHERE g.charttime <= DATETIME_ADD(b.intime, INTERVAL 24 HOUR)
),
first_abnormal_gcs AS (
  SELECT stay_id, MIN(charttime) AS first_abnormal_gcs_time
  FROM gcs_full WHERE gcs < 15
  GROUP BY stay_id
),
first_day_gcs AS (
  SELECT stay_id, MIN(gcs) AS first_day_gcs FROM gcs_full GROUP BY stay_id
),
adult_patients AS (
  SELECT v.*, a.age, p.gender
  FROM valid_icu v
  JOIN `physionet-data.mimiciv_3_1_derived.age` a ON v.hadm_id = a.hadm_id
  JOIN `physionet-data.mimiciv_3_1_hosp.patients` p ON v.subject_id = p.subject_id
  WHERE a.age >= 18
),
final_cohort AS (
  SELECT DISTINCT
    a.*,
    s.sofa_score, s.sepsis3, s.culture_time, s.sofa_time,
    g.first_day_gcs,
    fg.first_abnormal_gcs_time,
    IF(DATETIME_DIFF(GREATEST(s.culture_time, s.sofa_time), a.intime, HOUR) < 24,1,0) AS sepsis3_firstday,
    IF(first_day_gcs=15,1,0) AS normal_GCS  -- 缺失=0(异常)
  FROM adult_patients a
  LEFT JOIN `physionet-data.mimiciv_3_1_derived.sepsis3` s ON a.stay_id = s.stay_id
  LEFT JOIN first_day_gcs g ON a.stay_id = g.stay_id
  LEFT JOIN first_abnormal_gcs fg ON a.stay_id = fg.stay_id
)
SELECT * FROM final_cohort;
"

df <- bq_table_download(bq_project_query(projectid, sql_main), page_size = 100000)

# ==============================================
# 2. CAM‑ICU + 谵妄药（正确24h最早一条）
# ==============================================
cam_icu <- read.csv("~/Desktop/cam_icu.csv", stringsAsFactors = FALSE)
delirium_drug <- read.csv("~/Desktop/delirium_drug.csv", stringsAsFactors = FALSE)

drug_use <- delirium_drug %>%
  group_by(stay_id) %>%
  summarise(drug_used = as.integer(any(delirium_drug_rate > 0, na.rm=T)))

cam_clean <- cam_icu %>%
  left_join(df[, c("stay_id","intime")], by="stay_id") %>%
  filter(as.POSIXct(charttime) <= as.POSIXct(intime) + 24*3600) %>%
  arrange(stay_id, charttime) %>%
  distinct(stay_id, .keep_all=T) %>%
  select(stay_id, cam_icu = cam_icu_derived)

df_final <- df %>%
  left_join(drug_use, by="stay_id") %>%
  left_join(cam_clean, by="stay_id") %>%
  mutate(
    first_day_drug_used = coalesce(drug_used, 0),
    first_day_cam_icu = case_when(
      cam_icu == "Positive" ~ 1,
      cam_icu == "Negative" ~ 0
    )
  )

# ==============================================
# 3. 目标队列：sepsis3 + GCS abnormal
# ==============================================
df_teacher <- df_final %>%
  filter(sepsis3 == TRUE, normal_GCS == 0)

h <- unique(df_teacher$hadm_id)
s <- unique(df_teacher$stay_id)

# ==============================================
